{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AdriansVevside: Debug web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dev: start mariadb and build",
      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Adrians/Adrians.csproj",
        "--no-build"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Adrians/Views"
      }
    },
    {
      "name": "AdriansVevside: Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}