@model Adrians.ViewModels.PublicDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<section class="public-dashboard fade-in">
    <div class="dashboard-shell">

        <header class="dashboard-header dashboard-header-minimal">
            <div class="dashboard-clock">
                <div id="DashboardClockTime">--:--</div>
                <div id="DashboardClockDate" class="dashboard-muted">--</div>
            </div>

            <p class="dashboard-muted dashboard-updated">
                @Model.Stadnamn · oppdatert @Model.SistOppdatert.ToString("HH:mm")
            </p>
        </header>

        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="dashboard-alert">
                @statusMessage
            </div>
        }

        <div class="dashboard-grid dashboard-grid-main">

            <article class="dashboard-card dashboard-card-wide dashboard-weather-card">
                <div class="dashboard-card-header">
                    <div>
                        <p class="dashboard-card-kicker">Vêr</p>
                    </div>
                    <span class="dashboard-card-badge">met.no</span>
                </div>

                @if (Model.Korttidsvarsel is not null)
                {
                    <div class="dashboard-weather-large">
                        <partial name="_KorttidsvarselCard" model="Model.Korttidsvarsel"/>
                    </div>
                }
                else
                {
                    <p class="dashboard-muted mb-0">
                        Klarte ikkje hente vêr akkurat no.
                    </p>
                }
            </article>

            <div class="dashboard-match-card-stack">
                @if (Model.NesteSogndalKamp is not null)
                {
                    <partial name="_NesteKampCard" model="Model.NesteSogndalKamp"/>
                }
                else
                {
                    <article class="dashboard-card dashboard-next-match-card">
                        <div class="dashboard-card-header">
                            <div>
                                <p class="dashboard-card-kicker">Neste Sogndal-kamp</p>
                            </div>
                            <span class="dashboard-card-badge">NIFS</span>
                        </div>

                        <p class="dashboard-muted mb-0">
                            Ingen komande kamp funnen akkurat no.
                        </p>
                    </article>
                }

                @if (Model.NesteBarcelonaKamp is not null)
                {
                    <partial name="_NesteKampCard" model="Model.NesteBarcelonaKamp"/>
                }
                else
                {
                    <article class="dashboard-card dashboard-next-match-card">
                        <div class="dashboard-card-header">
                            <div>
                                <p class="dashboard-card-kicker">Neste Barça-kamp</p>
                            </div>
                            <span class="dashboard-card-badge">NIFS</span>
                        </div>

                        <p class="dashboard-muted mb-0">
                            Ingen komande kamp funnen akkurat no.
                        </p>
                    </article>
                }
            </div>

        </div>

        @if (Model.PiStatus is not null)
        {
            var piStatusClass = Model.PiStatus.IsOk
                ? "dashboard-pi-status-ok"
                : "dashboard-pi-status-warning";

            <article class="dashboard-card dashboard-pi-status-card @piStatusClass">
                <div class="dashboard-card-header">
                    <div>
                        <p class="dashboard-card-kicker">Pi-status</p>
                        <h2>VigdalPi</h2>
                    </div>

                    <span class="dashboard-card-badge">
                        @(Model.PiStatus.IsOk ? "OK" : "Sjekk")
                    </span>
                </div>

                <div class="dashboard-pi-status-main">
                    <div>
                        <span class="dashboard-pi-status-dot"></span>
                        <strong>
                            @(Model.PiStatus.IsOk ? "Siste deploy var OK" : "Deploy-status er uklar")
                        </strong>
                    </div>

                    @if (Model.PiStatus.DeployedAt is not null)
                    {
                        <p class="dashboard-muted">
                            Sist deploya @Model.PiStatus.DeployedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </p>
                    }
                    else
                    {
                        <p class="dashboard-muted">
                            Ingen deploy-tid registrert.
                        </p>
                    }
                </div>

                <dl class="dashboard-pi-status-details">
                    @if (!string.IsNullOrWhiteSpace(Model.PiStatus.CommitShort))
                    {
                        <div>
                            <dt>Commit</dt>
                            <dd>@Model.PiStatus.CommitShort</dd>
                        </div>
                    }

                    @if (Model.PiStatus.ResponseMs is not null)
                    {
                        <div>
                            <dt>Respons</dt>
                            <dd>@Model.PiStatus.ResponseMs ms</dd>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.PiStatus.DotnetRuntime))
                    {
                        <div>
                            <dt>.NET</dt>
                            <dd>@Model.PiStatus.DotnetRuntime</dd>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.PiStatus.AppEnvironment))
                    {
                        <div>
                            <dt>Miljø</dt>
                            <dd>@Model.PiStatus.AppEnvironment</dd>
                        </div>
                    }
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.PiStatus.Message))
                {
                    <p class="dashboard-muted mb-0">
                        @Model.PiStatus.Message
                    </p>
                }
            </article>
        }


        <div class="dashboard-grid dashboard-grid-countdowns">
            @foreach (var countdown in Model.Countdowns)
            {
                var logoClass = countdown.Id switch
                {
                    "CountdownSTR" => "dashboard-event-logo dashboard-event-logo-str",
                    "CountdownLFI" => "dashboard-event-logo dashboard-event-logo-lfi",
                    _ => "dashboard-event-logo"
                };

                <article class="dashboard-card dashboard-countdown-card">
                    @if (!string.IsNullOrWhiteSpace(countdown.BildeUrl))
                    {
                        <img src="@countdown.BildeUrl"
                             alt="@countdown.AltTekst"
                             class="@logoClass"/>
                    }

                    <p class="dashboard-card-kicker">@countdown.Undertittel</p>
                    <h2>@countdown.Tittel</h2>

                    <div class="dashboard-countdown"
                         id="@countdown.Id"
                         data-target="@countdown.Tidspunkt.ToUnixTimeMilliseconds()">
                        --
                    </div>
                </article>
            }
        </div>

        <div class="dashboard-grid dashboard-grid-links">
            @foreach (var link in Model.Links)
            {
                <a class="dashboard-link-card" href="@link.Url">
                    <strong>@link.Tittel</strong>
                    <span>@link.Tekst</span>
                </a>
            }
        </div>

        <footer class="dashboard-footer">
            <span>© @DateTime.Now.Year · Adrians</span>
        </footer>

    </div>
</section>

<script>
    function updateClock() {
        const now = new Date();

        document.getElementById("DashboardClockTime").textContent =
            now.toLocaleTimeString("nb-NO", {
                hour: "2-digit",
                minute: "2-digit"
            });

        document.getElementById("DashboardClockDate").textContent =
            now.toLocaleDateString("nb-NO", {
                weekday: "long",
                day: "numeric",
                month: "long"
            });
    }

    function updateCountdown(element) {
        const target = Number(element.dataset.target);
        const diff = target - Date.now();

        if (diff <= 0) {
            element.textContent = "No!";
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((diff / (1000 * 60)) % 60);
        const seconds = Math.floor((diff / 1000) % 60);

        element.textContent = `${days}d ${hours}t ${minutes}m ${seconds}s`;
    }

    function tick() {
        updateClock();

        document
            .querySelectorAll(".dashboard-countdown[data-target]")
            .forEach(updateCountdown);
    }

    tick();
    setInterval(tick, 1000);
</script>